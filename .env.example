# ============================================================
# OpenClaw Trader — Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Discord ──────────────────────────────────────────────────
# Official bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Comma-separated or JSON array of allowed Discord snowflake IDs
DISCORD_ALLOWED_GUILD_IDS=["123456789012345678"]
DISCORD_ALLOWED_CHANNEL_IDS=["111222333444555666"]
DISCORD_ALLOWED_ROLE_IDS=["777888999000111222"]

# ── IBKR Connection ───────────────────────────────────────────
# TWS paper=7497, TWS live=7496, Gateway paper=4002, Gateway live=4001
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_ID=DU123456

# ── Risk ──────────────────────────────────────────────────────
# Absolute dollar value of the trading sleeve (not full account NAV)
SLEEVE_VALUE=100000

# Hard limits
MAX_OPEN_POSITIONS=10

# Daily drawdown halt threshold (fraction of sleeve)
MAX_DAILY_DRAWDOWN_PCT=0.05

# ── Mode ──────────────────────────────────────────────────────
# CRITICAL: default is true; must be explicitly set false for live trading
PAPER_MODE=true

# OpenClaw strategy profile (maps to config/profiles/<profile>.toml)
PROFILE=discord_equities

# ── LLM (OpenAI) ──────────────────────────────────────────────
# Used by the Interpreter Agent to parse narrative Discord signals.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model to use for signal extraction (gpt-4o-mini ~$0.0002/signal)
LLM_MODEL=gpt-4o-mini

# Set to false to disable LLM parsing (regex-only mode)
LLM_ENABLED=true

# Signals scored below this clarity threshold are dropped (0-100)
LLM_MIN_CLARITY=50

# Seconds before an LLM call is abandoned
LLM_TIMEOUT_SECONDS=8.0

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
# LOG_FILE=logs/openclawtrader.log
